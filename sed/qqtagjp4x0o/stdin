        "/api/sf/customer/{customer}/correlations/pipes": {
            "post": {
                "tags": [
                    "Correlations"
                ],
                "summary": "Make correlation between loggers.",
                "description": "Calculates latest correlation between loggers.",
                "operationId": "post_api_correlation_pipe_create",
                "parameters": [
                    {
                        "name": "customer",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "first_logger",
                                    "second_logger",
                                    "pipes"
                                ],
                                "properties": {
                                    "first_logger": {
                                        "description": "Id of the first logger.",
                                        "type": "integer",
                                        "example": 44
                                    },
                                    "second_logger": {
                                        "description": "Id of the second logger.",
                                        "type": "integer",
                                        "example": 66
                                    },
                                    "pipes": {
                                        "description": "List of the pipes between loggers.",
                                        "type": "array",
                                        "items": {
                                            "required": [
                                                "correlation_material",
                                                "pipe_length"
                                            ],
                                            "properties": {
                                                "correlation_material": {
                                                    "description": "Id of the correlation material.",
                                                    "type": "integer",
                                                    "example": 1
                                                },
                                                "pipe_length": {
                                                    "description": "Length of the pipe in meters.",
                                                    "type": "integer",
                                                    "example": 100
                                                }
                                            },
                                            "type": "object"
                                        }
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Returns correlation between given loggers.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/ApiCorrelation"
                                    }
                                }
                            }
                        }
                    },
                    "400": {
