
if [ -e "$LOCKFILE" ]; then
  exit 1
fi

touch "$LOCKFILE"
trap 'rm -f "$LOCKFILE"; exit' INT TERM EXIT

# Linkare app db dalla GUI
TOKEN=$(sqlite3 /opt/sefthy-cpe-gui/app.db "SELECT token FROM config")
if [[ -z "$TOKEN" || ! "$TOKEN" =~ ^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$ ]]; then
  DEV=$(ip r | grep default | cut -d ' ' -f 5)
  IP=$(ip a show dev $DEV | grep -E -o 'inet [0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}' | cut -d' ' -f2)
  SERIAL=$(cat /etc/device*serial.conf)
  curl -X POST -s "$API/$GETIPSERIAL_EP" -d "{\"ip\":\"$IP\", \"serial_number\":\"$SERIAL\"}" -H "Content-Type: application/json" >/dev/n>
  exit 1
fi
